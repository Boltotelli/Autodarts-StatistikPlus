name: Build and Release Statistik+

on:
  workflow_dispatch:
    inputs:
      version:
        description: 'Release version, z. B. 0.4.30'
        required: true
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  build:
    runs-on: ubuntu-latest
    env:
      GITHUB_USER: Boltotelli
      GITHUB_REPO: Autodarts-StatistikPlus
      EXTENSION_ID: gikocipgcbbaddbbocecdphicbnmlkcj
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Determine version
        shell: bash
        run: |
          if [ "${{ github.event_name }}" = "workflow_dispatch" ]; then
            VERSION="${{ inputs.version }}"
          else
            VERSION="${GITHUB_REF_NAME#v}"
          fi
          echo "RELEASE_VERSION=$VERSION" >> "$GITHUB_ENV"
          echo "RELEASE_TAG=v$VERSION" >> "$GITHUB_ENV"
          echo "CRX_NAME=statistik-plus-v$VERSION.crx" >> "$GITHUB_ENV"
          echo "ZIP_NAME=statistik-plus-source-v$VERSION.zip" >> "$GITHUB_ENV"

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Install CRX packer
        run: npm install -g crx3

      - name: Restore private key from secret
        shell: bash
        env:
          CHROME_EXTENSION_KEY_B64: ${{ secrets.CHROME_EXTENSION_KEY_B64 }}
        run: |
          if [ -z "$CHROME_EXTENSION_KEY_B64" ]; then
            echo "GitHub Secret CHROME_EXTENSION_KEY_B64 fehlt."
            exit 1
          fi
          echo "$CHROME_EXTENSION_KEY_B64" | base64 -d > extension-private-key.pem
          chmod 600 extension-private-key.pem

      - name: Prepare manifest, update.xml and source zip
        run: python scripts/build_release.py

      - name: Build CRX
        run: |
          mkdir -p dist
          crx3 source --keyPath extension-private-key.pem --crxPath "dist/$CRX_NAME"

      - name: Commit version bump and update.xml back to main
        if: github.ref_type == 'tag' || github.event_name == 'workflow_dispatch'
        shell: bash
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add source/manifest.json update.xml
          if git diff --cached --quiet; then
            echo "Nichts zu committen."
          else
            git commit -m "Release $RELEASE_TAG"
            git push origin HEAD:main
          fi

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: ${{ env.RELEASE_TAG }}
          generate_release_notes: true
          files: |
            dist/${{ env.CRX_NAME }}
            dist/${{ env.ZIP_NAME }}
            update.xml
